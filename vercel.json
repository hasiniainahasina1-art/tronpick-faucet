{
  "functions": {
    "api/login.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 60,
      "memory": 2048,
      "env": {
        "BROWSERLESS_TOKEN": "@browserless_token",
        "PROXY_USERNAME": "@proxy_username",
        "PROXY_PASSWORD": "@proxy_password"
      }
    },
    "api/accounts.js": {
      "env": {
        "GH_TOKEN": "@gh_token",
        "GH_USERNAME": "@gh_username",
        "GH_REPO": "@gh_repo",
        "GH_BRANCH": "@gh_branch",
        "GH_FILE_PATH": "@gh_file_path"
      }
    }
  }
}
